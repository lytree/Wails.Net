<?xml version="1.0" encoding="utf-8"?>
<!--
  nuget.config
  本仓库的 NuGet 配置。

  - 注册本地包源 artifacts/nupkg/，用于 SDK 改造后的 Demo 测试。
    当 Demo 通过 PackageReference 引用 Wails.Net.Sdk 等包时，NuGet 会从此目录解析。
    运行 `dotnet pack` 时将生成的 .nupkg 输出到 artifacts/nupkg/（见 Directory.Build.props 的 PackageOutputPath）。

  - 保留官方 nuget.org 源用于第三方依赖。
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="Wails.Net.Local" value="artifacts/nupkg" />
  </packageSources>
</configuration>
