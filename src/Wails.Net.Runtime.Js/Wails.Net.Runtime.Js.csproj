<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>true</IsPackable>
    <PackageId>Wails.Net.Runtime.Js</PackageId>
    <Description>Wails.Net 前端运行时 JS 生成器：window.wails API 注入模板。</Description>
  </PropertyGroup>

  <!--
    在编译期生成 JsTemplates.g.cs，将 Resources\*.template.js 嵌入为 C# 静态字符串常量。
    替代运行时 Assembly.GetManifestResourceStream 反射调用，遵循 AGENTS.md §3.4。
    使用 C# 11+ 原始字符串字面量（"""..."""）避免转义。
  -->
  <Target Name="GenerateJsTemplates" BeforeTargets="CoreCompile"
          Inputs="Resources\transport.template.js;Resources\runtime.template.js;Resources\desktop.template.js"
          Outputs="$(IntermediateOutputPath)JsTemplates.g.cs">
    <ItemGroup>
      <JsTemplateLines Include="// &lt;auto-generated/&gt;" />
      <JsTemplateLines Include="// &lt;no-generated/&gt; This file is generated by the GenerateJsTemplates MSBuild target. Do not edit." />
      <JsTemplateLines Include="namespace Wails.Net.Runtime.Js%3B" />
      <JsTemplateLines Include="/// &lt;summary&gt;" />
      <JsTemplateLines Include="/// 前端运行时 JS 模板常量。在编译期从 Resources/*.template.js 嵌入，避免运行时反射读取嵌入资源。" />
      <JsTemplateLines Include="/// &lt;/summary&gt;" />
      <JsTemplateLines Include="internal static class JsTemplates" />
      <JsTemplateLines Include="{" />
      <JsTemplateLines Include="    /// &lt;summary&gt;transport.template.js 模板内容。&lt;/summary&gt;" />
      <JsTemplateLines Include="    public const string Transport =" />
      <JsTemplateLines Include="&quot;&quot;&quot;" />
    </ItemGroup>
    <ReadLinesFromFile File="Resources\transport.template.js">
      <Output TaskParameter="Lines" ItemName="JsTemplateLines" />
    </ReadLinesFromFile>
    <ItemGroup>
      <JsTemplateLines Include="&quot;&quot;&quot;%3B" />
      <JsTemplateLines Include="    /// &lt;summary&gt;runtime.template.js 模板内容。&lt;/summary&gt;" />
      <JsTemplateLines Include="    public const string Runtime =" />
      <JsTemplateLines Include="&quot;&quot;&quot;" />
    </ItemGroup>
    <ReadLinesFromFile File="Resources\runtime.template.js">
      <Output TaskParameter="Lines" ItemName="JsTemplateLines" />
    </ReadLinesFromFile>
    <ItemGroup>
      <JsTemplateLines Include="&quot;&quot;&quot;%3B" />
      <JsTemplateLines Include="    /// &lt;summary&gt;desktop.template.js 模板内容。&lt;/summary&gt;" />
      <JsTemplateLines Include="    public const string Desktop =" />
      <JsTemplateLines Include="&quot;&quot;&quot;" />
    </ItemGroup>
    <ReadLinesFromFile File="Resources\desktop.template.js">
      <Output TaskParameter="Lines" ItemName="JsTemplateLines" />
    </ReadLinesFromFile>
    <ItemGroup>
      <JsTemplateLines Include="&quot;&quot;&quot;%3B" />
      <JsTemplateLines Include="}" />
    </ItemGroup>
    <WriteLinesToFile File="$(IntermediateOutputPath)JsTemplates.g.cs"
                      Lines="@(JsTemplateLines)"
                      Overwrite="true" />
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)JsTemplates.g.cs" AutoGen="true" />
    </ItemGroup>
  </Target>

</Project>
